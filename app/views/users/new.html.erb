<h1>Create New User</h1>

<!-- Display validation errors -->
<% if @user&.errors&.any? %>
  <div style="color: red; margin-bottom: 20px; padding: 10px; border: 1px solid red; background-color: #ffe6e6;">
    <h3><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h3>
    <ul>
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<!-- RAILS FORM_WITH MODEL-DRIVEN FORM WITH TURBO ENABLED -->
<%= form_with model: @user do |form| %>
  
  <div>
    <%= form.label :username %>
    <%= form.text_field :username, placeholder: "Enter your username" %>
  </div>

  <div>
    <%= form.label :email %>
    <%= form.email_field :email, placeholder: "example@example.com" %>
  </div>

  <div>
    <%= form.label :password %>
    <%= form.password_field :password, placeholder: "Enter secure password" %>
  </div>

  <%= form.submit "Create User" %>

<% end %>
